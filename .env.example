PORT=3000

# 上傳檔目錄（預設為專案根目錄 uploads/）。容器檔案系統唯讀時可設為 /tmp/uploads；
# 注意：無持久 Volume 時重啟後檔案會消失，建議正式環境掛儲存或使用物件儲存。
# UPLOAD_DIR=/tmp/uploads

# Local development DB configuration (optional).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=recycle_dpp_platform

# Zeabur MySQL configuration (optional; your Zeabur UI can set these).
# The app will automatically fall back to MYSQL_* env vars when DB_* are not set.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=recycle_dpp_platform

