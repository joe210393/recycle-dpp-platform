<h1>後台首頁</h1>
<p class="admin-muted">資料庫與 CRUD 已就緒；以下為快速統計與整條作業路線圖。</p>

<div class="admin-stat-grid">
  <div class="admin-stat-card">
    <div class="label">回收廠商數量</div>
    <div class="value"><%= counts.recyclers || 0 %></div>
  </div>
  <div class="admin-stat-card">
    <div class="label">回收批次數量</div>
    <div class="value"><%= counts.recycledBatches || 0 %></div>
  </div>
  <div class="admin-stat-card">
    <div class="label">材料批次數量</div>
    <div class="value"><%= counts.materialBatches || 0 %></div>
  </div>
  <div class="admin-stat-card">
    <div class="label">商品數量</div>
    <div class="value"><%= counts.products || 0 %></div>
  </div>
  <div class="admin-stat-card">
    <div class="label">商品批次數量</div>
    <div class="value"><%= counts.productBatches || 0 %></div>
  </div>
  <div class="admin-stat-card">
    <div class="label">商品護照數量</div>
    <div class="value"><%= counts.productPassports || 0 %></div>
  </div>
</div>

<h2>整條路線圖（五大區塊，可展開）</h2>
<p class="admin-muted">水平五步驟呈現，點每一塊可展開管理項目。處理紀錄請由「材料」區塊進入。</p>

<div class="admin-flow-wrap">
  <div class="admin-flow">
    <div class="admin-flow-step">
      <details open>
        <summary class="step-summary">
          <span class="flow-num">1</span>
          回收
        </summary>
        <div class="flow-links">
          <a href="/admin/recyclers">回收廠商</a>
          <a href="/admin/recycled-items">回收物類型</a>
          <a href="/admin/recycled-batches">回收批次</a>
        </div>
      </details>
    </div>

    <div class="admin-flow-arrow">&gt;</div>

    <div class="admin-flow-step">
      <details>
        <summary class="step-summary">
          <span class="flow-num">2</span>
          材料
        </summary>
        <div class="flow-links">
          <a href="/admin/processing-records">處理紀錄</a>
          <a href="/admin/materials">材料主檔</a>
          <a href="/admin/material-batches">材料批次</a>
        </div>
      </details>
    </div>

    <div class="admin-flow-arrow">&gt;</div>

    <div class="admin-flow-step">
      <details>
        <summary class="step-summary">
          <span class="flow-num">3</span>
          商品
        </summary>
        <div class="flow-links">
          <a href="/admin/products">商品</a>
          <a href="/admin/product-versions">商品版本</a>
          <a href="/admin/product-bom">商品 BOM</a>
          <a href="/admin/product-batches">商品批次</a>
          <a href="/admin/product-batch-material-batches">商品用料鏈結</a>
        </div>
      </details>
    </div>

    <div class="admin-flow-arrow">&gt;</div>

    <div class="admin-flow-step">
      <details>
        <summary class="step-summary">
          <span class="flow-num">4</span>
          護照
        </summary>
        <div class="flow-links">
          <a href="/admin/documents">文件附件</a>
          <a href="/admin/product-passports">商品護照</a>
          <a href="/admin/passport-views">護照顯示設定</a>
        </div>
      </details>
    </div>

    <div class="admin-flow-arrow">&gt;</div>

    <div class="admin-flow-step">
      <details>
        <summary class="step-summary">
          <span class="flow-num">5</span>
          DPP 匯出
        </summary>
        <div class="flow-links">
          <a href="/admin/dpp-exports">DPP 匯出</a>
        </div>
      </details>
    </div>
  </div>
</div>
